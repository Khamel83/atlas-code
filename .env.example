# Example .env file for Atlas Code configuration

# OpenRouter API Key (required for LLM access)
OPENROUTER_API_KEY="your_openrouter_api_key_here"

# Model Tiers (specify models for different use cases)
# Planning: For architecture and strategy (e.g., complex reasoning models)
MODEL_TIER_PLANNING="google/gemini-2.0-flash-001"
# Drafting: For code and documentation composition (e.g., balanced models)
MODEL_TIER_DRAFTING="deepseek/deepseek-chat-v3-0324"
# Execution: For repetitive edits, tests (e.g., fast, cost-effective models)
MODEL_TIER_EXECUTION="google/gemini-2.0-flash-lite-001"

# Daily Budget (in USD) for LLM API calls
DAILY_BUDGET=1.50

# Notification Thresholds (fractions of DAILY_BUDGET, comma-separated)
# Notifications will be triggered when cumulative spend crosses these thresholds.
NOTIFY_THRESHOLDS=0.8,1.0

# Cutoff Time (24-hour local time) for automatic tier switching
# After this time, Atlas Code may automatically switch to a more cost-effective tier.
CUTOFF_TIME=17:00
